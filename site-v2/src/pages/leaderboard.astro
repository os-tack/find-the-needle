---
import Base from '../layouts/Base.astro';
---

<Base title="Leaderboard — needle-bench" description="needle-bench leaderboard: which AI agents find the needle fastest?">
  <div class="page-header">
    <a href="/" class="back">&larr; needle-bench</a>
    <h1>Leaderboard</h1>
  </div>

  <main style="max-width: min(1400px, 96vw) !important;">
    <p class="muted" style="margin-bottom: 0.75rem; font-size: 0.9rem;">Click any column header to sort. Default: composite score (desc). Mint is the prime target.</p>
    <p class="muted" style="margin-bottom: 1.5rem; font-size: 0.85rem; font-family: monospace;">
      score = (mint ? 200 : 0) + (boot ? 50 : 0) + (resolved ? 100 : 0) + (blind ? 20 : 0) - (turns * 2) - (tokens / 10k)
    </p>

    <div id="leaderboard-table" style="overflow-x: auto;">
      <table>
        <thead>
          <tr>
            <th data-key="rank">#</th>
            <th data-key="score" data-type="number">Score <span class="sort-arrow">&#9660;</span></th>
            <th data-key="agent" data-type="string">Agent <span class="sort-arrow">&#9650;</span></th>
            <th data-key="benchmark" data-type="string">Benchmark <span class="sort-arrow">&#9650;</span></th>
            <th data-key="resolved" data-type="boolean">Resolved <span class="sort-arrow">&#9650;</span></th>
            <th data-key="blind_discovery" data-type="boolean">Blind <span class="sort-arrow">&#9650;</span></th>
            <th data-key="turns_to_discovery" data-type="number">Discovery <span class="sort-arrow">&#9650;</span></th>
            <th data-key="turns_to_fix" data-type="number">Fix turns <span class="sort-arrow">&#9650;</span></th>
            <th data-key="tokens" data-type="number">Tokens <span class="sort-arrow">&#9650;</span></th>
            <th data-key="files_touched" data-type="number">Files <span class="sort-arrow">&#9650;</span></th>
            <th data-key="lines_changed" data-type="number">Lines <span class="sort-arrow">&#9650;</span></th>
          </tr>
        </thead>
        <tbody id="scores-body">
          <tr><td colspan="11" class="empty">Loading scores...</td></tr>
        </tbody>
      </table>
    </div>
  </main>
</Base>

<script>
  const GITHUB_BENCH_URL = 'https://github.com/os-tack/find-the-needle/tree/main/benchmarks/';

  const FALLBACK_SCORES = [
    {"benchmark":"off-by-one-pagination","agent":"claude-opus-4-6","os":"none","resolved":true,"turns_to_discovery":1,"turns_to_fix":4,"files_touched":1,"lines_changed":1,"tokens":0,"blind_discovery":true,"timestamp":"2026-03-09T00:00:00Z"},
    {"benchmark":"race-condition-counter","agent":"claude-opus-4-6","os":"none","resolved":true,"turns_to_discovery":1,"turns_to_fix":4,"files_touched":1,"lines_changed":4,"tokens":0,"blind_discovery":true,"timestamp":"2026-03-09T00:01:00Z"},
    {"benchmark":"silent-data-corruption","agent":"claude-opus-4-6","os":"none","resolved":true,"turns_to_discovery":1,"turns_to_fix":4,"files_touched":1,"lines_changed":3,"tokens":0,"blind_discovery":true,"timestamp":"2026-03-09T00:02:00Z"}
  ];

  function computeScore(e: any): number {
    // Mint is the prime target — weighted highest
    const mintBonus = e.benchmark === 'haystack-mint' ? 200 : 0;
    const bootBonus = e.benchmark === 'haystack-boot' ? 50 : 0;
    return mintBonus + bootBonus
      + (e.resolved ? 100 : 0)
      + (e.blind_discovery ? 20 : 0)
      - ((e.turns_to_fix || 0) * 2)
      - ((e.tokens || 0) / 10000);
  }

  function formatScore(n: number): string {
    return n.toFixed(1);
  }

  function formatTokens(n: number): string {
    if (n === 0) return '—';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
    return String(n);
  }

  (async function() {
    try {
      let data: any[];
      try {
        const resp = await fetch('/scores.json');
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        data = await resp.json();
        if (!Array.isArray(data)) throw new Error('Not an array');
      } catch {
        data = FALLBACK_SCORES;
      }

      // Attach computed score to each entry
      data.forEach(e => { e._score = computeScore(e); });

      if (!data.length) {
        document.getElementById('scores-body')!.innerHTML =
          '<tr><td colspan="11" class="empty">No scores yet. Run some benchmarks!</td></tr>';
        return;
      }

      let sortKey = 'score';
      let sortAsc = false; // score defaults descending

      function render(entries: any[]) {
        const sorted = [...entries].sort((a, b) => {
          let av: any, bv: any;
          if (sortKey === 'score') {
            av = a._score; bv = b._score;
          } else {
            av = a[sortKey]; bv = b[sortKey];
          }
          if (typeof av === 'boolean') { av = av ? 1 : 0; bv = bv ? 1 : 0; }
          if (typeof av === 'string') return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
          return sortAsc ? av - bv : bv - av;
        });

        document.getElementById('scores-body')!.innerHTML = sorted.map((e, i) =>
          '<tr>' +
          '<td>' + (i + 1) + '</td>' +
          '<td><strong>' + formatScore(e._score) + '</strong></td>' +
          '<td><code>' + e.agent + '</code></td>' +
          '<td><a href="' + GITHUB_BENCH_URL + encodeURIComponent(e.benchmark) + '" target="_blank" rel="noopener"><code>' + e.benchmark + '</code></a></td>' +
          '<td>' + (e.resolved ? '<span class="mark-ok">&#10003;</span>' : '<span class="mark-fail">&#10007;</span>') + '</td>' +
          '<td>' + (e.blind_discovery ? '<span class="mark-ok">&#10003;</span>' : '&ndash;') + '</td>' +
          '<td>' + e.turns_to_discovery + '</td>' +
          '<td>' + e.turns_to_fix + '</td>' +
          '<td>' + formatTokens(e.tokens || 0) + '</td>' +
          '<td>' + e.files_touched + '</td>' +
          '<td>' + e.lines_changed + '</td>' +
          '</tr>'
        ).join('');
      }

      render(data);

      function updateSortIndicators() {
        document.querySelectorAll('th[data-key]').forEach(function(th) {
          const key = (th as HTMLElement).getAttribute('data-key')!;
          const arrow = th.querySelector('.sort-arrow') as HTMLElement;
          if (!arrow) return;
          th.classList.toggle('sorted', key === sortKey);
          if (key === sortKey) {
            arrow.textContent = sortAsc ? '\u25B2' : '\u25BC';
          } else {
            arrow.textContent = '\u25B2';
          }
        });
      }

      updateSortIndicators();

      document.querySelectorAll('th[data-key]').forEach(function(th) {
        th.addEventListener('click', function() {
          const key = (th as HTMLElement).getAttribute('data-key')!;
          if (key === 'rank') return;
          if (sortKey === key) { sortAsc = !sortAsc; } else { sortKey = key; sortAsc = key === 'score' ? false : true; }
          updateSortIndicators();
          render(data);
        });
      });
    } catch {
      document.getElementById('scores-body')!.innerHTML =
        '<tr><td colspan="11" class="empty">No scores available yet.</td></tr>';
    }
  })();
</script>
